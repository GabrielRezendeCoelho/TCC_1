          <mxGeometry x="20" y="90" width="380" height="1020" as="geometry" />
        </mxCell>

        <!-- SWIM LANE: BACKEND -->
        <mxCell id="lane-sys" value="SISTEMA — API NestJS + PostgreSQL" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="90" width="460" height="1020" as="geometry" />
        </mxCell>

        <!-- SWIM LANE: MOTORISTA -->
        <mxCell id="lane-drv" value="MOTORISTA (App Mobile)" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="90" width="380" height="1020" as="geometry" />
        </mxCell>

        <!-- SWIM LANE: CLIENTE -->
        <mxCell id="lane-cli" value="CLIENTE (Rastreamento)" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1300" y="90" width="360" height="1020" as="geometry" />
        </mxCell>

        <!-- ===== OPERADOR ===== -->
        <mxCell id="start" value="INICIO" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontSize=12;fontStyle=1;" vertex="1" parent="lane-op">
          <mxGeometry x="130" y="60" width="120" height="45" as="geometry" />
        </mxCell>

        <mxCell id="op-login" value="Login com email + senha" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane-op">
          <mxGeometry x="100" y="145" width="180" height="45" as="geometry" />
        </mxCell>

        <mxCell id="op-packages" value="Cadastrar Pacotes&#xa;(endereco, peso, cliente, telefone)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane-op">
          <mxGeometry x="100" y="250" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="op-route" value="Criar Rota&#xa;(selecionar pacotes + motorista)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane-op">
          <mxGeometry x="100" y="360" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="op-optimize" value="Solicitar Otimizacao de Rota" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane-op">
          <mxGeometry x="100" y="470" width="180" height="45" as="geometry" />
        </mxCell>

        <mxCell id="op-monitor" value="Monitorar Dashboard&#xa;(entregas em tempo real)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane-op">
          <mxGeometry x="100" y="720" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="op-report" value="Visualizar Relatorios e Ocorrencias" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane-op">
          <mxGeometry x="100" y="880" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- ===== SISTEMA ===== -->
        <mxCell id="sys-auth" value="Autenticar via JWT&#xa;(Validar role: ADMIN / OPERATOR)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-sys">
          <mxGeometry x="130" y="145" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="sys-geo" value="Geocodificar Endereco do Pacote&#xa;(lat/lng via Google Maps API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-sys">
          <mxGeometry x="130" y="250" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="sys-save-route" value="Salvar Rota como DRAFT&#xa;(associar pacotes e motorista)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-sys">
          <mxGeometry x="130" y="360" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="sys-algo" value="Algoritmo de Otimizacao TSP&#xa;(Nearest Neighbor Heuristico)&#xa;Minimiza distancia total das paradas&#xa;Salva ordem em optimizedOrder (JSON)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="lane-sys">
          <mxGeometry x="110" y="465" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="sys-route-opt" value="Status da Rota: OPTIMIZED&#xa;Salvo no banco PostgreSQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-sys">
          <mxGeometry x="130" y="590" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="sys-notify" value="Notificar Motorista&#xa;(rota disponivel no app)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-sys">
          <mxGeometry x="130" y="670" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="sys-tracking" value="Registrar Evento de Tracking&#xa;(status, lat/lng, timestamp)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-sys">
          <mxGeometry x="130" y="780" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="sys-audit" value="Registrar AuditLog&#xa;(toda acao critica e rastreavel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-sys">
          <mxGeometry x="130" y="880" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="db" value="PostgreSQL + Prisma ORM" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;fontStyle=1;" vertex="1" parent="lane-sys">
          <mxGeometry x="160" y="955" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- ===== MOTORISTA ===== -->
        <mxCell id="drv-login" value="Login no App Mobile&#xa;(role: DRIVER)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="lane-drv">
          <mxGeometry x="95" y="145" width="190" height="50" as="geometry" />
        </mxCell>

        <mxCell id="drv-receive" value="Receber Rota Otimizada&#xa;(lista de paradas ordenadas)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="lane-drv">
          <mxGeometry x="95" y="670" width="190" height="50" as="geometry" />
        </mxCell>

        <mxCell id="drv-start" value="Iniciar Entrega&#xa;(Rota: IN_PROGRESS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="lane-drv">
          <mxGeometry x="95" y="760" width="190" height="50" as="geometry" />
        </mxCell>

        <mxCell id="drv-decision" value="Entrega&#xa;Bem-sucedida?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="lane-drv">
          <mxGeometry x="115" y="850" width="150" height="65" as="geometry" />
        </mxCell>

        <mxCell id="drv-proof" value="Registrar Prova de Entrega&#xa;(foto + assinatura + nome)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane-drv">
          <mxGeometry x="85" y="955" width="190" height="50" as="geometry" />
        </mxCell>

        <mxCell id="drv-occurrence" value="Registrar&#xa;Ocorrencia" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane-drv">
          <mxGeometry x="280" y="855" width="90" height="65" as="geometry" />
        </mxCell>

        <!-- ===== CLIENTE ===== -->
        <mxCell id="cli-track" value="Consultar Rastreamento&#xa;via Codigo de Rastreio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane-cli">
          <mxGeometry x="80" y="250" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="cli-history" value="Ver Historico de Status&#xa;(PENDING → IN_ROUTE → DELIVERED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane-cli">
          <mxGeometry x="80" y="380" width="200" height="55" as="geometry" />
        </mxCell>

        <mxCell id="cli-notif" value="Receber Notificacao&#xa;de Entrega Confirmada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane-cli">
          <mxGeometry x="80" y="955" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- ===== SETAS — OPERADOR ===== -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="op-login" parent="lane-op">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="op-login" target="op-packages" parent="lane-op">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="op-packages" target="op-route" parent="lane-op">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="op-route" target="op-optimize" parent="lane-op">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== SETAS — SISTEMA ===== -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys-auth" target="sys-geo" parent="lane-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys-geo" target="sys-save-route" parent="lane-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys-save-route" target="sys-algo" parent="lane-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys-algo" target="sys-route-opt" parent="lane-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys-route-opt" target="sys-notify" parent="lane-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys-tracking" target="sys-audit" parent="lane-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys-audit" target="db" parent="lane-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== SETAS — MOTORISTA ===== -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="drv-receive" target="drv-start" parent="lane-drv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="drv-start" target="drv-decision" parent="lane-drv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="SIM" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="drv-decision" target="drv-proof" parent="lane-drv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" value="NAO" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="drv-decision" target="drv-occurrence" parent="lane-drv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== SETAS ENTRE LANES ===== -->
        <!-- Operador → Sistema: Login -->
        <mxCell id="cross1" value="POST /auth/login" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#6c8ebf;" edge="1" source="op-login" target="sys-auth" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Operador → Sistema: Geocode pacotes -->
        <mxCell id="cross2" value="POST /packages" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#6c8ebf;" edge="1" source="op-packages" target="sys-geo" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Operador → Sistema: Criar rota -->
        <mxCell id="cross3" value="POST /routes" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#6c8ebf;" edge="1" source="op-route" target="sys-save-route" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Operador → Sistema: Otimizar -->
        <mxCell id="cross4" value="POST /routes/:id/optimize" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d6b656;" edge="1" source="op-optimize" target="sys-algo" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Sistema → Motorista: notificar -->
        <mxCell id="cross5" value="Rota disponivel" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" source="sys-notify" target="drv-receive" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Motorista → Sistema: tracking events -->
        <mxCell id="cross6" value="POST /tracking" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d6b656;" edge="1" source="drv-start" target="sys-tracking" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Motorista login → Sistema auth -->
        <mxCell id="cross7" value="POST /auth/login" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d6b656;" edge="1" source="drv-login" target="sys-auth" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Sistema tracking → Cliente -->
        <mxCell id="cross8" value="GET /packages/:code/tracking" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#b85450;" edge="1" source="sys-tracking" target="cli-history" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Sistema audit → Operador monitor -->
        <mxCell id="cross9" value="GET /dashboard" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#6c8ebf;" edge="1" source="sys-audit" target="op-monitor" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Prova de entrega → Notif cliente -->
        <mxCell id="cross10" value="Entrega confirmada" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" source="drv-proof" target="cli-notif" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Cliente consulta -->
        <mxCell id="cross11" value="GET /packages/:code/tracking" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#b85450;" edge="1" source="cli-track" target="sys-geo" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

