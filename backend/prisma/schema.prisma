// Prisma Schema — TrackGo MVP
// Modelos de domínio para o sistema de logística com roteirização inteligente

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Role {
  ADMIN
  OPERATOR
  DRIVER
  CLIENT
}

enum PackageStatus {
  PENDING
  IN_ROUTE
  DELIVERED
  RETURNED
  FAILED
}

enum RouteStatus {
  DRAFT
  OPTIMIZED
  IN_PROGRESS
  COMPLETED
}

enum DeliveryStatus {
  SUCCESS
  FAILED
}

enum OccurrenceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// --- Models ---

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(DRIVER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver        Driver?
  client        Client?
  routesCreated Route[]      @relation("CreatedByUser")
  auditLogs     AuditLog[]
  occurrences   Occurrence[] @relation("ReportedByUser")

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  document  String   @unique // CPF or CNPJ
  phone     String
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  packages Package[]

  @@map("clients")
}

model Driver {
  id            String   @id @default(uuid())
  licenseNumber String   @unique // CNH
  phone         String
  userId        String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  routes       Route[]
  vehicle      Vehicle?       @relation(fields: [vehicleId], references: [id])
  vehicleId    String?

  @@map("drivers")
}

model Vehicle {
  id           String   @id @default(uuid())
  plate        String   @unique
  model        String
  capacityKg   Float
  capacityVol  Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  drivers Driver[]

  @@map("vehicles")
}

model Package {
  id             String        @id @default(uuid())
  trackingCode   String        @unique @default(uuid())
  recipientName  String
  recipientPhone String?
  address        String
  latitude       Float?
  longitude      Float?
  weight         Float?
  status         PackageStatus @default(PENDING)
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])

  routeId        String?
  route          Route?        @relation(fields: [routeId], references: [id], onDelete: SetNull)
  
  trackingEvents Tracking[]
  deliveryProof  DeliveryProof?
  occurrences    Occurrence[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("packages")
}

model Route {
  id              String      @id @default(uuid())
  name            String
  date            DateTime
  status          RouteStatus @default(DRAFT)
  startAddress    String?
  optimizedOrder  Json?
  totalDistance   Float?
  estimatedTime   Float?
  
  driverId        String?
  driver          Driver?     @relation(fields: [driverId], references: [id], onDelete: SetNull)
  
  createdById     String
  createdBy       User        @relation("CreatedByUser", fields: [createdById], references: [id])
  
  packages        Package[]
  occurrences     Occurrence[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("routes")
}

model Tracking {
  id          String   @id @default(uuid())
  packageId   String
  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  status      PackageStatus
  location    String?
  latitude    Float?
  longitude   Float?
  timestamp   DateTime @default(now())

  @@map("tracking_events")
}

model DeliveryProof {
  id              String         @id @default(uuid())
  packageId       String         @unique
  package         Package        @relation(fields: [packageId], references: [id], onDelete: Cascade)
  status          DeliveryStatus
  signatureUrl    String?
  photoUrl        String?
  receiverName    String?
  receiverDoc     String?        // Document of the person who received it
  deliveryDate    DateTime       @default(now())
  notes           String?

  @@map("delivery_proofs")
}

model Occurrence {
  id          String             @id @default(uuid())
  title       String
  description String
  severity    OccurrenceSeverity @default(LOW)
  
  packageId   String?
  package     Package?           @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  routeId     String?
  route       Route?             @relation(fields: [routeId], references: [id], onDelete: Cascade)

  reportedById String
  reportedBy   User              @relation("ReportedByUser", fields: [reportedById], references: [id])

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("occurrences")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String
  details     Json?
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@map("audit_logs")
}
